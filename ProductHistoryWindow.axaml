<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="500"
        x:Class="MSM.ProductHistoryWindow"
        Title="재고 변경 내역"
        Width="700"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SemiGrey1Color}">

    <DockPanel Margin="20">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,16">
            <TextBlock Text="재고 변경 내역"
                       FontSize="24"
                       FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Name="ProductNameText"
                           FontSize="15"
                           FontWeight="Medium"/>
                <Border Background="{DynamicResource SemiGrey2Color}"
                        CornerRadius="4"
                        Padding="8,4">
                    <TextBlock Name="BarcodeText"
                               FontSize="14"
                               FontFamily="Consolas, Monaco, monospace"/>
                </Border>
            </StackPanel>
        </StackPanel>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SemiGrey0Color}"
                CornerRadius="8"
                Padding="16"
                Margin="0,16,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="24">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="총 변경 건수:"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Name="TotalCountText"
                                   Text="0건"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="총 변경 수량:"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Name="TotalChangedText"
                                   Text="0개"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1"
                        Name="CloseButton"
                        Content="닫기"
                        Padding="20,8"
                        FontSize="14"/>
            </Grid>
        </Border>

        <!-- Data Grid -->
        <Border Background="{DynamicResource SemiGrey0Color}"
                CornerRadius="8"
                Padding="8">
            <DataGrid Name="HistoryDataGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserReorderColumns="False"
                      CanUserResizeColumns="True"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      x:CompileBindings="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="날짜"
                                        Binding="{Binding DateFormatted}"
                                        Width="100"/>
                    <DataGridTextColumn Header="시간"
                                        Binding="{Binding TimeFormatted}"
                                        Width="80"/>
                    <DataGridTextColumn Header="변경 전"
                                        Binding="{Binding OldQty}"
                                        Width="80"/>
                    <DataGridTextColumn Header="변경 후"
                                        Binding="{Binding NewQty}"
                                        Width="80"/>
                    <DataGridTextColumn Header="변경"
                                        Binding="{Binding ChangedQty}"
                                        Width="70"/>
                    <DataGridTextColumn Header="사유"
                                        Binding="{Binding Reason}"
                                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</Window>
